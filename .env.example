# OAuth2 Configuration for pramari.de
OAUTH_CLIENT_ID=your_client_id_here
OAUTH_CLIENT_SECRET=your_client_secret_here
OAUTH_REDIRECT_URL=de.pramari.coach:/oauth2redirect
OAUTH_AUTHORIZATION_ENDPOINT=https://id.pramari.de/application/o/authorize/
OAUTH_TOKEN_ENDPOINT=https://id.pramari.de/application/o/token/
OAUTH_DISCOVERY_URL=https://id.pramari.de/application/o/coach/.well-known/openid-configuration
