# OAuth2 Configuration for pramari.de
OAUTH_CLIENT_ID=your_client_id_here
OAUTH_CLIENT_SECRET=your_client_secret_here
OAUTH_REDIRECT_URL=de.pramari.coach:/oauth2redirect
OAUTH_AUTHORIZATION_ENDPOINT=https://pramari.de/oauth2/authorize
OAUTH_TOKEN_ENDPOINT=https://pramari.de/oauth2/token
OAUTH_DISCOVERY_URL=https://pramari.de/.well-known/openid-configuration
